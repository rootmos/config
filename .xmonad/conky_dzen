background yes
out_to_console yes
out_to_x no
# Update interval in seconds
update_interval 2

TEXT
^fg(\#aaaaaa) eth:${exec eth-is-active}^fg(\#FFFFFF) \
| ^fg(\#aaaaaa)D: ${downspeedf enp3s0}kib/s^fg(\#FFFFFF) ^fg(\#aaaaaa)U: ${upspeedf enp3s0}kib/s^fg(\#FFFFFF) \
| ^fg(\#aaaaaa)C:${cpu}% T:${hwmon 2 temp 1}° S:${swapperc}% M:${memperc}%^fg(\#FFFFFF) \
| ^fg(\#aaaaaa)${time %d-%m-%Y} ^fg(\#ebac54) ${time %R}
